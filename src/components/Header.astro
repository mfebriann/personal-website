---
import logo from '/assets/logo.png';
---

<header class="bg-transparent backdrop-blur-sm border-b border-slate-200/10 p-4 sticky top-0 duration-500 transition-colors ease-in-out z-40" id="header">
	<nav class="flex items-center justify-between relative main-container">
		<a href="/">
			<img src={logo} alt="logo" class="w-9 sm:w-12" />
		</a>
		<button type="button" class="w-4 h-full flex flex-col gap-y-2 overflow-hidden sm:hidden" id="btn-menu">
			<div class="h-[2px] bg-amber-300 duration-500 transition-all w-full"></div>
			<div class="h-[2px] bg-amber-300 duration-500 transition-all w-full"></div>
			<div class="h-[2px] bg-amber-300 duration-500 transition-all w-full"></div>
		</button>
		<ul
			class="absolute right-0 z-40 bg-slate-800 ring-1 ring-slate-200/30 py-2 rounded-sm top-16 space-y-1 w-48 scale-0 opacity-0 duration-500 sm:static sm:bg-transparent sm:opacity-100 sm:scale-100 sm:space-y-0 sm:ring-0 sm:flex sm:items-center sm:gap-x-6 sm:w-auto sm:transition-none"
		>
			<li><a href="#about" class="link-menu">About</a></li>
			<li><a href="#experience" class="link-menu">Experience</a></li>
			<li><a href="#projects" class="link-menu">Projects</a></li>
			<li>
				<a href="/resume.pdf" class="link-menu border border-amber-300 mt-5 rounded-md mx-5 text-center text-amber-300 sm:m-0 sm:px-5 sm:py-2 sm:hover:bg-white/10" target="_blank">Resume</a>
			</li>
		</ul>
	</nav>
</header>

<style>
	#btn-menu.btn-menu-active > * {
		background-color: #fff;
	}

	#btn-menu.btn-menu-active > *:first-child {
		transform: rotate(135deg) translate3d(5px, -5px, 0);
	}

	#btn-menu.btn-menu-active > *:nth-child(2) {
		transform: translateX(60px);
	}

	#btn-menu.btn-menu-active > *:last-child {
		transform: rotate(-135deg) translate3d(5.8px, 5.8px, 0) translate(3px, 3px);
	}

	#btn-menu.btn-menu-active ~ ul {
		opacity: 1;
		transform: scale(1);
		display: block;
	}
</style>

<script>
	const header = document.getElementById('header');
	window.addEventListener('scroll', function () {
		if (scrollY >= 1) {
			header.classList.replace('bg-transparent', 'bg-white/5');
		} else {
			header.classList.replace('bg-white/5', 'bg-transparent');
		}
	});

	const btnMenu = document.getElementById('btn-menu');
	btnMenu.addEventListener('click', function () {
		this.classList.toggle('btn-menu-active');
	});

	btnMenu.addEventListener('blur', function () {
		this.classList.remove('btn-menu-active');
	});
</script>
